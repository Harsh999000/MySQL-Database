           s.normalized_name, s.normalized_company
    FROM enrichment_jobs ej
    JOIN speakers s ON ej.speaker_id = s.speaker_id
    WHERE ej.attempt_count < ej.max_attempts
      AND (
            ej.status = 'pending'
            OR (
                ej.status = 'retry_scheduled'
                AND ej.started_at IS NOT NULL
